# Optional: set a password to protect the UI (leave empty for no auth)
KB_PASSWORD=

# Optional: domain for the app
DOMAIN=localhost

# Optional: override the shared data directory.
# Defaults to ./data for source installs, or a managed app-data path in Electron.
# CABINET_DATA_DIR=

# Optional: release manifest URL for update checks.
# CABINET_RELEASE_MANIFEST_URL=https://github.com/hilash/cabinet/releases/latest/download/cabinet-release.json

# Optional: GitHub personal access token. Raises the registry API limit
# from 60/hr (unauthenticated) to 5000/hr. Any fine-grained token with
# public-repo read access is enough.
# GITHUB_TOKEN=

# Optional: override runtime ports and origins when embedding Cabinet in Electron.
# CABINET_APP_PORT=3000
# CABINET_DAEMON_PORT=3001
# CABINET_APP_ORIGIN=http://127.0.0.1:3000
# CABINET_PUBLIC_DAEMON_ORIGIN=ws://127.0.0.1:3001

# CABINET_DAEMON_URL=http://localhost:3001
# Optional: comma-separated list of additional allowed dev origins
# (127.0.0.1 and localhost are always included)
# CABINET_ALLOWED_DEV_ORIGINS=cabinet.example.com

# --- Docker / container runtime ---
# Required when running via docker-compose. When running from source these are optional.
#
# Fine-grained GitHub PAT. Scope it to only the repos Cabinet is allowed to read/write,
# with Contents: Read & write and Metadata: Read. Nothing else.
# GITHUB_TOKEN=github_pat_xxx
#
# Git identity used for auto-commits inside the container.
# GIT_AUTHOR_NAME=Cabinet Agent
# GIT_AUTHOR_EMAIL=agent@example.com

# --- Linked repositories ---
# Each repo you want to expose to Cabinet gets its own env var pointing at the
# absolute host path. The repo is mounted inside the container at
# /repos/<basename>, and that is the path you type into Cabinet's "Link Repo"
# dialog. Add more repos by appending another HOST_REPO_* var here and another
# volume line in docker-compose.yml under the cabinet service.
# HOST_REPO_BUSINESS_RESEARCH=/Users/localuser/code/business_research
